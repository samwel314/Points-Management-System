@model CustomerProfileVM

@{
    int idCount = 0;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">

        <div class="mb-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left"></i> العودة للرئيسية
            </a>
        </div>

        <div class="mb-2 text-center">
            <h6 class="text-muted mb-1">
                <i class="bi bi-stars"></i> إجمالي نقاطك
            </h6>
            <h2 class="fw-bold text-success">⭐ @Model.TotalPoints</h2>
        </div>

        <div class="mb-2">
            <a asp-controller="Invoice" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> إضافة فاتورة
            </a>
        </div>

    </div>

    @if (!Model.Invoices.Any())
    {
        <div class="card shadow-sm border-0 text-center mt-4">
            <div class="card-body py-5">
                <i class="bi bi-receipt text-muted fs-1 mb-3"></i>

                <h5 class="card-title mb-2">لا توجد فواتير</h5>

                <p class="card-text text-muted">
                    لم تقم بإضافة أي فواتير حتى الآن
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var invoice in Model.Invoices)
            {
                <div class="col-12 col-md-6 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-bold">
                                    <i class="bi bi-receipt me-1"></i>
                                    كود الفاتورة: @invoice.code
                                </span>

                                <span class="badge bg-success">
                                    <i class="bi bi-star-fill me-1"></i>
                                    @invoice.Points نقطة
                                </span>
                            </div>

                            <p class="mb-1 text-muted">
                                <i class="bi bi-shop me-1"></i>
                                المتجر: @invoice.storeName
                            </p>

                            <p class="mb-3 text-muted">
                                <i class="bi bi-calendar-event me-1"></i>
                                التاريخ: @invoice.Date
                            </p>

                            <div class="mt-auto text-end">
                                <a asp-controller="Invoice"
                                   asp-action="Update"
                                   asp-route-Id="@invoice.Id"
                                   class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil-square me-1"></i>
                                    تعديل
                                </a>

                                <button type="button"
                                        class="btn btn-outline-info btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#imageModal-@idCount">
                                    <i class="bi bi-image me-1"></i>
                                    عرض الصورة
                                </button>

                            </div>

                        </div>
                    </div>
                </div>

                <div class="modal fade" id="imageModal-@idCount" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content">

                            <div class="modal-header">
                                <h5 class="modal-title fw-bold">
                                    <i class="bi bi-image me-2"></i> عرض / تعديل صورة الفاتورة
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body text-center">

                                @if (!string.IsNullOrEmpty(invoice.ImagePath))
                                {
                                    <img src="~/InvoicesImages/@invoice.ImagePath"
                                         class="img-fluid rounded shadow-sm mb-3"
                                         style="max-height:350px; object-fit:cover;" />
                                }
                                else
                                {
                                    <p class="text-muted">لا توجد صورة مرفوعة</p>
                                }

                                <form method="post"
                                      asp-controller="Invoice" asp-action="UpdateImage"
                                      enctype="multipart/form-data">

                                    <input type="hidden" name="Id" value="@invoice.Id" />
                                    <input type="hidden" name="url" value="@Context.Request.Path" />

                                    <div class="mb-3">
                                        <input type="file"
                                               name="NewImage"
                                               class="form-control"
                                               accept="image/*" />
                                    </div>

                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary fw-bold">
                                            <i class="bi bi-upload me-2"></i> تحديث الصورة
                                        </button>
                                    </div>

                                </form>

                            </div>

                        </div>
                    </div>
                </div>
                idCount++;
            }

        </div>
    }

</div>
