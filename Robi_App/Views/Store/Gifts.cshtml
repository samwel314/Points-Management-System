@model StoreGiftRequestVM

@{
    ViewData["Title"] = "إدارة طلبات الهدايا";
}

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-list-check text-primary me-2"></i>
                    إدارة طلبات الهدايا
                </h2>
                <a asp-controller="Store" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-2"></i>
                    العودة للفروع
                </a>
            </div>

            <!-- Store Name Section -->
            <div class="alert alert-primary d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-shop fs-3 me-3"></i>
                <div>
                    <h5 class="mb-0 fw-bold">فرع: @Model.Title</h5>
                    <small class="text-muted">عرض طلبات الهدايا الخاصة بهذا الفرع</small>
                </div>
            </div>

            @if (Model.giftRequests == null || !Model.giftRequests.Any())
            {
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    <h5>لا توجد طلبات حالياً</h5>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th><i class="bi bi-person me-2"></i>اسم العميل</th>
                                <th><i class="bi bi-telephone me-2"></i>رقم الهاتف</th>
                                <th><i class="bi bi-house me-2"></i>ملاحظات </th>
                                <th><i class="bi bi-gift me-2"></i>الهدية</th>
                                <th><i class="bi bi-star me-2"></i>النقاط</th>
                                <th><i class="bi bi-calendar me-2"></i>وقت الطلب</th>
                                <th><i class="bi bi-info-circle me-2"></i>الحالة</th>
                                <th class="text-center">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.giftRequests)
                            {
                                <tr>
                                    <td class="fw-bold">@request.CustomerName</td>
                                    <td>@request.CustomerPhone</td>
                                    <td>@request.Notes</td>

                                    <td>@request.GiftName</td>
                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            @request.GiftPoints نقطة
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        @request.RequestDate.ToString("dd/MM/yyyy")
                                    </td>
                                    <td>
                                        @if (request.IsApproved)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i>
                                                متاحة
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-x-circle me-1"></i>
                                                غير متاحة
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <!-- Toggle Availability -->
                                            <form method="post" asp-action="ToggleAvailability" class="d-inline">
                                                <input type="hidden" name="Id" value="@request.Id" />
                                                <input type="hidden" name="Url" value="@Context.Request.Path" />

                                                @if (request.IsApproved)
                                                {
                                                    <button type="submit" class="btn btn-warning btn-sm" title="إلغاء التوفير">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                         إلغاء التوفير 
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-success btn-sm" title="تأكيد التوفير">
                                                        <i class="bi bi-check-circle-fill"></i>
                                                        توفير
                                                    </button>
                                                }
                                            </form>

                                            <!-- Delete -->
                                            <button class="btn btn-danger btn-sm"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#deleteConfirm-@request.Id"
                                                    title="حذف الطلب">
                                                <i class="bi bi-trash-fill"></i>
                                                حذف
                                            </button>
                                        </div>

                                        <!-- Delete Confirmation -->
                                        <div class="collapse mt-2" id="deleteConfirm-@request.Id">
                                            <div class="alert alert-danger mb-0 p-2">
                                                <p class="mb-2 small">
                                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                    هل أنت متأكد من حذف هذا الطلب؟
                                                </p>
                                                <form method="post" asp-action="DeleteGiftRequest" class="d-inline">
                                                    <input type="hidden" name="Id" value="@request.Id" />
                                                    <input type="hidden" name="Url" value="@Context.Request.Path" />

                                                    <div class="d-flex gap-2">
                                                        <button type="submit" class="btn btn-danger btn-sm flex-fill">
                                                            نعم، احذف
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-secondary btn-sm flex-fill"
                                                                data-bs-toggle="collapse"
                                                                data-bs-target="#deleteConfirm-@request.Id">
                                                            إلغاء
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>