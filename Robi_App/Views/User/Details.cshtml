@model EmployeeVM
<div class="container mt-4" dir="rtl">

    <!-- زر العودة للرئيسية -->
    <div class="mb-3 text-start">
        <a asp-controller="Employee" asp-action="show" class="btn btn-outline-primary fw-bold">
            <i class="bi bi-arrow-left fw-bold"></i> العودة للموظفين
        </a>
    </div>

    <!-- معلومات العميل -->
    <div class="card shadow-sm mb-4">
        <div class="card-body text-center">

            <h5 class="mb-2">
                <i class="bi bi-person-circle"></i> @Model.FullName
            </h5>

            <p class="text-muted mb-2">
                <i class="bi bi-telephone"></i> @Model.PhoneNumber
            </p>
            <p class="text-muted mb-2">
                <i class="bi bi-house-gear-fill"></i> @(Model.StoreName == null ? "فرع هذاالموظف غير متاح " : $"فرع {Model.StoreName}   ")
            </p>
            <div class="mt-2">
                @if (Model.IsLocked)
                {
                    <a asp-controller="User" asp-action="UnLock" asp-route-Id="@Model.EmployeeId" asp-route-url="@Context.Request.Path" class="btn btn-outline-success btn-sm fw-bold">
                        <i class="bi bi-person-x"></i> الغاء تعطيل الحساب
                    </a>
                }
                else
                {
                    <a asp-controller="User" asp-action="Lock" asp-route-Id="@Model.EmployeeId" asp-route-url="@Context.Request.Path" class="btn btn-outline-warning btn-sm fw-bold">
                        <i class="bi bi-person-x"></i> تعطيل الحساب
                    </a>
                }
            </div>
            <div class="mt-2">

                <button type="button" class="btn btn-outline-danger btn-sm fw-bold" onclick="document.getElementById('deleteFormContainer').style.display='block'">
                    مسح الحساب
                </button>
            </div>

            <div id="deleteFormContainer" style="display:none; margin-top:10px;">
                <form method="post" asp-controller="User" asp-action="Delete">
                    <input type="hidden" name="Id" value="@Model.EmployeeId" />
                    <input type="hidden" name="url" value="@Url.Action("Show", "Employee")" />

                    <p>هل أنت متأكد أنك تريد مسح الحساب نهائيًا؟</p>

                    <button type="submit" class="btn btn-danger btn-sm fw-bold">نعم، امسح الحساب</button>
                    <button type="button" class="btn btn-secondary btn-sm fw-bold" onclick="document.getElementById('deleteFormContainer').style.display='none'">إلغاء</button>
                </form>
            </div>
        </div>
    </div>
    </div>