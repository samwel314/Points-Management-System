@model IEnumerable<ShowGiftVM>

<div class="container mt-4">
    <div class="mb-4 text-start">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary fw-bold">
            <i class="bi bi-arrow-left fw-bold"></i> العودة للرئيسية
        </a>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
        <h2 class="text-primary fw-bold mb-2 text-center flex-grow-1">
            <i class="bi bi-gift"></i>الهداية
        </h2>
        <a asp-controller="Gift" asp-action="Create"
           class="btn btn-primary btn-sm fw-bold mb-2">
            <i class="bi bi-gift"></i> إضافة هدية جديدة
        </a>
    </div>

    <div class="row g-4">

        @foreach (var gift in Model)
        {

            <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">

                <div class="card h-100 shadow-sm border-0">

                    <img src="~/GiftsImages/@gift.ImagePath"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;">

                    <div class="card-body text-center">

                        <h5 class="fw-bold">@gift.Name</h5>
                        <span class="badge bg-dark-subtle fs-6">
                            ⭐     @gift.points    
                        </span>                      
                        <div class="d-flex fs-4 fw-bold justify-content-center gap-2 mt-3">

                            <!-- Update Name -->
                            <button class="btn btn-primary btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#updateName-@gift.Id">
                                تعديل الاسم
                            </button>

                            <!-- Update Image -->
                            <button class="btn btn-warning btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#updateImage-@gift.Id">
                                تعديل الصورة
                            </button>

                            <!-- Delete -->
                            <button class="btn btn-danger btn-sm"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#deleteConfirm-@gift.Id">
                                حذف
                            </button>

                        </div>

                        <!-- Confirm Delete -->
                        <div class="collapse mt-3" id="deleteConfirm-@gift.Id">

                            <form method="post" asp-action="Delete">

                                <input type="hidden" name="Id" value="@gift.Id" />

                                <p class="text-danger small">
                                    سيتم حذف الهدية وجميع طلابتها !
                                </p>

                                <button class="btn btn-danger btn-sm w-100">
                                    نعم احذف
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>


            <!-- Update Name Modal -->

            <div class="modal fade" id="updateName-@gift.Id">

                <div class="modal-dialog modal-dialog-centered">

                    <div class="modal-content">

                        <div class="modal-header">

                            <h5 class="modal-title">
                                تعديل اسم الهدية
                            </h5>

                            <button class="btn-close"
                                    data-bs-dismiss="modal"></button>

                        </div>

                        <form method="post" asp-action="UpdateName">

                            <div class="modal-body">

                                <input type="hidden"
                                       name="Id"
                                       value="@gift.Id" />

                                <label class="form-label">
                                    اسم الهدية
                                </label>

                                <input type="text"
                                       class="form-control"
                                       name="NewName"
                                       value="@gift.Name" />

                            </div>

                            <div class="modal-footer">
                                <button class="btn btn-primary">
                                    حفظ
                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </div>



            <!-- Update Image Modal -->

            <div class="modal fade" id="updateImage-@gift.Id">

                <div class="modal-dialog modal-dialog-centered">

                    <div class="modal-content">

                        <div class="modal-header">

                            <h5 class="modal-title">
                                تغير الصورة
                            </h5>

                            <button class="btn-close"
                                    data-bs-dismiss="modal"></button>

                        </div>

                        <form method="post" asp-action="UpdateImage"
                              enctype="multipart/form-data">

                            <div class="modal-body text-center">

                                <input type="hidden"
                                       name="Id"
                                       value="@gift.Id" />

                                <p class="fw-bold">
                                    الصورة الحالية
                                </p>

                                <img src="~/GiftsImages/@gift.ImagePath"
                                     class="img-fluid mb-3 rounded"
                                     style="max-height:150px;" />

                                <input type="file"
                                       class="form-control"
                                       name="Image" />

                            </div>

                            <div class="modal-footer">


                                <button class="btn btn-warning">
                                    تغيير الصورة
                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        }

    </div>

</div>