@model IEnumerable<ClientRequestsVM>

@{
    ViewData["Title"] = "طلباتي";
}

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-list-check text-primary me-2"></i>
                    طلبات الهدايا
                </h2>
                <div class="d-flex gap-2">
                    <a asp-action="Display" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-2"></i>
                        طلب هدية جديدة
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left me-2"></i>
                        العودة للرئيسية
                    </a>
                </div>
            </div>
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    <h5>لا توجد طلبات حالياً</h5>
                    <p class="text-muted">قم بطلب هدية من القائمة المتاحة</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var request in Model)
                    {
                        <div class="col-lg-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body p-3">
                                    <!-- Header -->
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h6 class="fw-bold text-primary mb-0">
                                            <i class="bi bi-gift-fill me-2"></i>
                                            @request.GiftName
                                        </h6>
                                        <span class="badge bg-warning text-dark">
                                            @request.Points نقطة
                                        </span>
                                    </div>

                                    <!-- Details -->
                                    <div class="mb-3 small">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-geo-alt-fill text-danger me-3"></i>
                                            <span class="text-muted">فرع الاستلام:</span>
                                            <strong class="ms-2">@request.StoreName</strong>
                                        </div>

                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-calendar3 text-primary me-3"></i>
                                            <span class="text-muted">تاريخ الطلب:</span>
                                            <strong class="ms-2">@request.CreatedAt.ToString("dd/MM/yyyy")</strong>
                                        </div>

                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-info-circle-fill me-3"></i>
                                            <span class="text-muted">حالة الطلب:</span>
                                            @if (request.IsApproved)
                                            {
                                                <span class="ms-2 badge bg-success">
                                                    <i class="bi bi-check-circle-fill me-1"></i>
                                                    مقبول
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="ms-2 badge bg-warning text-dark">
                                                    <i class="bi bi-clock-history me-1"></i>
                                                    قيد المراجعة
                                                </span>
                                            }
                                        </div>

                                        @if (!string.IsNullOrEmpty(request.Notes))
                                        {
                                            <div class="mt-2 p-2 bg-light rounded">
                                                <i class="bi bi-chat-left-text text-secondary me-3"></i>
                                                <span class="text-muted">ملاحظة:</span>
                                                <p class="mb-0 mt-1">@request.Notes</p>
                                            </div>
                                        }
                                    </div>

                                    <!-- Delete Button -->
                                    <div class="d-grid">
                                        <button class="btn btn-danger btn-sm"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#deleteConfirm-@request.Id">
                                            <i class="bi bi-trash-fill me-2"></i>
                                            حذف الطلب
                                        </button>
                                    </div>

                                    <!-- Delete Confirmation -->
                                    <div class="collapse mt-2" id="deleteConfirm-@request.Id">
                                        <div class="alert alert-danger mb-0 p-2">
                                            <p class="mb-2 small">
                                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                                هل أنت متأكد من حذف هذا الطلب؟
                                            </p>
                                            <form method="post" asp-action="DeleteGiftRequest">
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <div class="d-flex gap-2">
                                                    <button type="submit" class="btn btn-danger btn-sm flex-fill">
                                                        نعم، احذف
                                                    </button>
                                                    <button type="button"
                                                            class="btn btn-secondary btn-sm flex-fill"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#deleteConfirm-@request.Id">
                                                        إلغاء
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>